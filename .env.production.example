# ─────────────────────────────────────────────────────────────────────────────
# FiveCrux — PRODUCTION environment template
# Copy to your host's env (Vercel project settings / .env.production.local) and
# fill every value. Do NOT commit real secrets.
#
# IMPORTANT: the app THROWS on boot in production if NEXTAUTH_SECRET is missing
# or the dev default, or if any dev-harness flag below is "true". That is on
# purpose — the local test harness must never be reachable in production.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core ---------------------------------------------------------------------
# Real Postgres connection string (Neon / Supabase / RDS / etc.)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/fivecrux
# Strong unique random value, e.g. `openssl rand -base64 32`. NOT the dev default.
NEXTAUTH_SECRET=__GENERATE_A_STRONG_RANDOM_SECRET__
# Your public site URL (used for OAuth callbacks + payment return URLs)
NEXTAUTH_URL=https://your-domain.com

# --- Discord OAuth (login) ----------------------------------------------------
# From https://discord.com/developers — add NEXTAUTH_URL/api/auth/callback/discord
# as an authorized redirect.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Tebex (payments, Model B) ------------------------------------------------
# FiveCrux's OWN store public token (platform fees: ad slots, featured slots).
TEBEX_PUBLIC_TOKEN=
TEBEX_PRIVATE_KEY=
# Webhook signing secret (Tebex dashboard → Webhooks). Required to verify events.
TEBEX_WEBHOOK_SECRET=
# (Per-seller store tokens / package ids are stored per product in the DB, not here.)

# --- PayPal (legacy — still wired until Tebex is verified end-to-end) ----------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=live

# Primary checkout provider for platform fees (ad/featured slots).
# Keep "paypal" until FiveCrux's Tebex store + package map (lib/tebex-packages.ts)
# are configured and verified, then switch to "tebex".
NEXT_PUBLIC_PAYMENT_PROVIDER=paypal
# TEBEX_MOCK MUST be unset/false in production (only for local testing).

# --- AWS S3 (file uploads: images / prop zips) --------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=
AWS_S3_BUCKET_URL=

# --- Firebase (client analytics) ----------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_FIREBASE_AUTH_DOMAIN=

# --- Dev test-harness flags — MUST be absent or false in production -----------
# (Leave these unset/false. The boot-guard refuses to start if any is "true".)
# ALLOW_DEV_LOGIN=false
# USE_PGLITE=false
# NEXT_PUBLIC_MOCK_AUTH=false
# NEXT_PUBLIC_ALLOW_DEV_LOGIN=false
